{
  "name": "ai-connector",
  "displayName": "ai_connector",
  "description": "Allows the use of AI inside Visual Studio Code, including offline usage",
  "version": "0.0.1",
  "publisher": "danilo-silva",
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ai-connector.insertText",
        "title": "AI Connector: Insert Text"
      },
      {
        "command": "ai-connector.testOllamaServer",
        "title": "AI Connector: Test AI Server"
      },
      {
        "command": "ai-connector.manageExtension",
        "title": "AI Connector: Manage Extension"
      },
      {
        "command": "ai-connector.openSettings",
        "title": "AI Connector: Open Settings"
      }
    ],
    "configuration": {
      "title": "AI Connector Host",
      "properties": {
        "ai-connector.ai_host": {
          "type": "string",
          "default": "localhost",
          "description": "Define the host address of your Ollama like AI address"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.125.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "ts-loader": "^9.5.4",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
